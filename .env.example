# Honeypot environment variables
# For the full backend configuration, copy proto.env.example to proto.env:
#   cp proto.env.example proto.env
#
# See proto.env.example for Azure, OpenAI, Gemini, and app-mode settings.

# Frontend (Vite) — set in frontend/.env or export before `npm run dev`
# VITE_API_BASE_URL=http://localhost:8000
# VITE_FORMSPREE_ENDPOINT=
# VITE_DISQUS_SHORTNAME=
# VITE_GISCUS_REPO=
# VITE_GISCUS_REPO_ID=
# VITE_GISCUS_CATEGORY=
# VITE_GISCUS_CATEGORY_ID=
